# SSH host config managed by dotfiles.
# Included from ~/.ssh/config via:  Include ~/andrkrn/dotfiles/ssh/config

Host andrkrn-desktop
    User andrkrn
    SetEnv TERM=xterm-256color
    # Detect/recover dead connections fast and survive idle NAT timeouts.
    ServerAliveInterval 20
    ServerAliveCountMax 3
    TCPKeepAlive yes

Host oracle
    User ubuntu
    SetEnv TERM=xterm-256color
    # Detect/recover dead connections fast and survive idle NAT timeouts.
    ServerAliveInterval 20
    ServerAliveCountMax 3
    TCPKeepAlive yes
