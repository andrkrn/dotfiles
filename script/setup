#!/usr/bin/env zsh
set -e

type -p brew >/dev/null || /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install.sh)"

for file in "$PWD"/*; do
  name="$(basename "$file" .md)"
  [[ $name = bin ]] && dotname="$name" || dotname=".${name}"

  [[ "README script vscode launchd claude ssh" =~ $name ]] && continue

  ln -sfnv ${file#$HOME/} "${HOME}/${dotname}"
done

mkdir -p "${HOME}/.claude"
ln -sfv "${PWD}/claude/settings.json" "${HOME}/.claude/settings.json"

# Include dotfiles-managed SSH host config (don't symlink ~/.ssh — it holds keys)
mkdir -p "${HOME}/.ssh"
touch "${HOME}/.ssh/config"
include_line="Include ${PWD}/ssh/config"
grep -qxF "$include_line" "${HOME}/.ssh/config" || \
  printf '\n# SSH hosts managed by dotfiles\n%s\n' "$include_line" >> "${HOME}/.ssh/config"

brew bundle --global --no-upgrade

# Install oh-my-zsh
export ZSH="$HOME/.oh-my-zsh"
[ -f $ZSH/oh-my-zsh.sh ] && \. $ZSH/oh-my-zsh.sh
command -v omz >/dev/null || /bin/sh -c "$(curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"

./script/install_code_extensions

# set screenshots folder for OSX
if [[ `uname` == "Darwin" ]]; then
  mkdir -p ~/Pictures/screenshots
  defaults write com.apple.screencapture location ~/Pictures/screenshots
fi

echo "Done!"

